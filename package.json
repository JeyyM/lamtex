{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n app,notify -c cyan,magenta \"npm run dev:app\" \"npm run dev:notify\"",
    "dev:app": "vite --port=3000 --host=0.0.0.0",
    "dev:notify": "tsx watch server/index.ts",
    "dev:vercel": "vercel dev",
    "build": "vite build && npm run build:api",
    "build:api": "tsup --config tsup.api.config.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "frimousse": "^0.3.0",
    "linkify-react": "^4.3.3",
    "linkifyjs": "^4.3.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "open-graph-scraper": "^6.11.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0",
    "resend": "^4.5.1",
    "serverless-http": "^4.0.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/google.maps": "^3.64.0",
    "@types/node": "^22.14.0",
    "@vercel/node": "^5.3.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.14",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
