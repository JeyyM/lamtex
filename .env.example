# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Google Maps (browser): create a key with "Maps JavaScript API" + "Places API" enabled (search/autocomplete).
# VITE_GOOGLE_MAPS_API_KEY="YOUR_BROWSER_KEY"

# Supabase (browser — set in Vercel for the frontend)
# VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
# VITE_SUPABASE_ANON_KEY="YOUR_ANON_KEY"

# Resend (server-side only — never expose to the browser). Used to send transactional emails
# (notifications, approvals, etc.). Create at https://resend.com → API Keys.
# Set these in Vercel Project → Settings → Environment Variables (not VITE_ prefixed).
RESEND_API_KEY="YOUR_RESEND_API_KEY"
RESEND_FROM_EMAIL="onboarding@resend.dev"

# Until launch: all notification emails go here instead of employee DB emails.
NOTIFICATIONS_EMAIL_OVERRIDE="jeymson9000@gmail.com"

# Local notification server (npm run dev:notify). Vite proxies /api → this port in dev.
# On Vercel, api/index.ts serves the same routes as serverless functions — no separate process.
NOTIFY_SERVER_PORT=3001

# Vercel Cron (/api/cron/overdue-payments, daily 06:00 UTC) — same Vercel project, not a separate service.
# Vercel sends Authorization: Bearer <CRON_SECRET> on scheduled runs. Rotate before production.
CRON_SECRET="lamtex-cron-dev-change-me"

# Service role key for cron only (server-side). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=""
# Optional; defaults to VITE_SUPABASE_URL if unset:
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
