{
  "buildCommand": "npm run build:api && vite build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index?originalPath=$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/health.ts": {
      "maxDuration": 10
    },
    "api/index.ts": {
      "maxDuration": 10,
      "includeFiles": "api/vercel-api.cjs"
    },
    "api/cron/overdue-payments.ts": {
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/cron/overdue-payments",
      "schedule": "0 6 * * *"
    }
  ]
}
